# ============================================================
# .gitignore — Proyecto PSC Plasma Simulation
# ============================================================

# ---- Build directories (CMake, ninja, make) ----
/build/
src/build/
*.o
*.a
*.so
*.so.*
*.dylib
*.exe
*.bin
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake
install_manifest.txt
CTestTestfile.cmake
_CPack_Packages/
Testing/
compile_commands.json

# ---- Generated images & plots (analysis output) ----
# These are regenerated by the analysis scripts — do NOT track
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.svg
*.eps
*.webp
*.ico

# Exception: libmrc documentation images (part of upstream PSC)
!src/libmrc/doc/**/*.png

# Exception: libmrc test reference data (regression tests)
!src/libmrc/tests/reference_results/**/*.dump
!src/libmrc/tests/reference_results/**/*.xdmf
!src/libmrc/tests/reference_results/**/*.log

# ---- Simulation data output (large binary files) ----
*.bp/
*.bp
*.h5
*.hdf5
*.mrc
*.sst
*.dump
*.xdmf
*.dat
*.npy
*.npz
*.pkl
*.pickle
*.csv
checkpoint_*/

# ---- Analysis output directories ----
plasma_results_temp/
CodeforAnalisysAdios2/
CodeforAnalisys/anisotropy_plots/
CodeforAnalisys/field_images/
CodeforAnalisys/mirror_plots/
CodeforAnalisys/diamagnetic_plots/
CodeforAnalisys/spectral_plots/
CodeforAnalisys/prt_plots/
CodeforAnalisys/fancy_vdf_plots/
CodeforAnalisys/phase_space_plots/
CodeforAnalisys/validation_plots/

# ---- Python ----
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
dist/
.eggs/
*.egg
.Python

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Editor / IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.codex
.cache/

# ---- Jupyter Notebooks (checkpoints) ----
.ipynb_checkpoints/

# ---- PDFs / Informes / Presentaciones ----
*.pdf
Informes/
informes/
Presentaciones/
presentaciones/
Reports/
reports/
slides/
*.pptx
*.ppt
*.docx
*.doc
*.xlsx
*.xls

# ---- LaTeX / TeX build artifacts ----
*.tex
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv
_minted-*/
*.pygtex
*.pygstyle
build_pdf.py

# ---- SLURM / HPC job files ----
*.out.slurm
slurm-*.out
job_*.sh

# ---- OS / System files ----
.DS_Store
Thumbs.db
desktop.ini
*.log

# ---- Archives ----
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar
